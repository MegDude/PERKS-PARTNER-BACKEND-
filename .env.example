# OPENAI_API_KEY: Backend-only key for the Downtown Perks Agent Gateway.
# Never expose this as a VITE_* variable.
OPENAI_API_KEY=""

# AI model configuration is centralized here so frontend pages never hardcode providers.
AI_CHAT_MODEL="gpt-4.1-mini"
AI_IMAGE_MODEL="gpt-image-1"
AI_EMBEDDING_MODEL="text-embedding-3-small"
AI_MODERATION_MODEL="omni-moderation-latest"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PORT: Local Express/Vite server port. Defaults to 3000.
PORT=3000

# GOOGLE_MAPS_API_KEY / GOOGLE_PLACES_API_KEY:
# Backend-only key for Google Places API enrichment.
# Enable Places API in Google Cloud, restrict the key to the Places API, and do not expose it as VITE_*.
GOOGLE_MAPS_API_KEY=""
GOOGLE_PLACES_API_KEY=""

# VITE_API_BASE_URL: Optional separate API origin for deployed frontends.
# Leave blank when the frontend and backend are served by this same Express app.
VITE_API_BASE_URL=""

# Firebase public web app config:
# These values are safe to expose to the browser, but they must come from the
# correct Firebase project. Keep private Firebase admin/service-account keys out
# of VITE_* variables.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
